{
  "name": "pino-huacho-cabin",
  "version": "1.0.0",
  "description": "Cabin booking website for Pino Huacho, Araucanía",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "db:update": "node config/updateDatabase.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pug": "^3.0.2",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.1.6",
    "express-session": "^1.17.3",
    "bcryptjs": "^2.4.3",
    "nodemailer": "^6.9.8",
    "express-validator": "^7.0.1",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2"
  }
}
  //- Location & Activities Section
  section.py-5.bg-light
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-6.fw-bold.text-section-title 
            | 🗺️ Ubicación y Actividades
          p.lead.text-section-lead Pino Huacho ofrece múltiples atractivos naturales y experiencias únicas
      

extends layout

block content
  section.py-5.mt-5
    .container
      .row
        .col-12.text-center.mb-5
          h1.display-4.fw-bold 
            | 🏠 Características de la Cabaña
          p.lead Descubre todo lo que nuestra cabaña tiene para ofrecerte en el corazón de la Araucanía

  section.py-5
    .container
      .row.g-4
        each feature in features
          .col-md-6.col-lg-4
            .card.h-100.shadow-sm.feature-card
              .card-body.text-center.p-4
                .feature-icon.mb-4
                  case feature.icon
                    when 'home'
                      | 🏠
                    when 'wifi'
                      | 📶
                    when 'car'
                      | 🚗
                    when 'flame'
                      | 🔥
                    when 'utensils'
                      | 🍽️
                    when 'tree-pine'
                      | 🌲
                    default
                      | ✨
                h5.card-title.fw-bold= feature.title
                p.card-text= feature.description

  //- Detailed Amenities Section
  section.py-5.bg-light
    .container
      .row
        .col-lg-6
          h2.display-6.fw-bold.mb-4 
            | ✨ Comodidades Completas
          .amenities-list
            .amenity-item.d-flex.align-items-center.mb-3
              | ✅
              span.ms-3 Ropa de cama 
            
            .amenity-item.d-flex.align-items-center.mb-3
              | ✅
              span.ms-3 TV 
            
            .amenity-item.d-flex.align-items-center.mb-3
              | ✅
              span.ms-3 Parrilla para asados al aire libre
            
            .amenity-item.d-flex.align-items-center.mb-3
              | ✅
              span.ms-3 Utensilios de cocina completos
              
            
            .amenity-item.d-flex.align-items-center.mb-3
              | ✅
              span.ms-3 Terraza con vista panorámica
        
        .col-lg-6
          .cabin-specs.p-4.rounded-3.shadow-sm
            h4.fw-bold.mb-4 
              | 📋 Especificaciones Técnicas
            
            .spec-row.d-flex.justify-content-between.py-3.border-bottom
              strong 
                | 👥 Capacidad máxima:
              span 5 personas
            
            .spec-row.d-flex.justify-content-between.py-3.border-bottom
              strong 
                | 🛏️ Habitaciones:
              span 2 (1 matrimoniales, 1 individual + Litera)
            
            .spec-row.d-flex.justify-content-between.py-3.border-bottom
              strong 
                | 🚿 Baños:
              span 1 completo
            
            .spec-row.d-flex.justify-content-between.py-3.border-bottom
              strong 
                | 📐 Superficie:
              span 50 m2 
            
            .spec-row.d-flex.justify-content-between.py-3.border-bottom
              strong 
                | 🕐 Check-in:
              span  a partir de las 15:00 hrs
            
            .spec-row.d-flex.justify-content-between.py-3
              strong 
                | 🕐 Check-out:
              span hasta las 11:00 hrs

  //- Photo Gallery Section
  section.py-5
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-6.fw-bold 
            | 📸 Galería de Fotos
          p.lead Explora cada rincón de nuestra acogedora cabaña

      .row.g-4
        .col-md-6.col-lg-4
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='https://images.pexels.com/photos/1396122/pexels-photo-1396122.jpeg', alt='Sala de estar')
            .gallery-overlay
              h5 
                | 🛋️ Sala de Estar
              p Espacio acogedor con chimenea y vista al bosque
        
        .col-md-6.col-lg-4
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='https://images.pexels.com/photos/1571460/pexels-photo-1571460.jpeg', alt='Cocina equipada')
            .gallery-overlay
              h5 
                | 🍽️ Cocina Equipada
              p Electrodomésticos modernos y utensilios completos
        
        .col-md-6.col-lg-4
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='https://images.pexels.com/photos/1438832/pexels-photo-1438832.jpeg', alt='Habitación principal')
            .gallery-overlay
              h5 
                | 🛏️ Habitación Principal
              p Cama matrimonial con ropa de cama 
        
        .col-md-6.col-lg-4
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='https://images.pexels.com/photos/1579253/pexels-photo-1579253.jpeg', alt='Vista exterior')
            .gallery-overlay
              h5 
                | 🌲 Vista Exterior
              p Arquitectura rústica integrada al paisaje
        
        .col-md-6.col-lg-4
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='https://images.pexels.com/photos/1396122/pexels-photo-1396122.jpeg', alt='Terraza')
            .gallery-overlay
              h5 
                | 🌅 Terraza
              p Espacio perfecto para relajarse y disfrutar la naturaleza
        
        .col-md-6.col-lg-4
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='https://images.pexels.com/photos/1438832/pexels-photo-1438832.jpeg', alt='Área de parrilla')
            .gallery-overlay
              h5 
                | 🔥 Área de Parrilla

        .col-md-6.col-lg-3
          .activity-card.text-center.p-4.h-100
            | 📸
            h5.mt-3.fw-bold.text-activity-title Fotografía
            p.text-muted.text-activity-desc Paisajes únicos ideales para capturar la belleza de la Araucanía
        
        .col-md-6.col-lg-3
          .activity-card.text-center.p-4.h-100
            | 🎣
            h5.mt-3.fw-bold.text-activity-title Pesca Deportiva
            p.text-muted.text-activity-desc Lagos y ríos cercanos con truchas y especies nativas
        
        .col-md-6.col-lg-3
          .activity-card.text-center.p-4.h-100
            | 🍃
            h5.mt-3.fw-bold.text-activity-title Observación Natural
            p.text-muted.text-activity-desc Flora y fauna nativa, aves endémicas y paisajes volcánicos

  //- Nearby Attractions
  section.py-5
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-6.fw-bold 
            | 🏔️ Atractivos Cercanos
          p.lead Descubre los lugares más visitados cerca de Lican Ray y Coñaripe

      .row.g-4
        .col-md-4
          .card.h-100.border-0.shadow-sm
            .card-body.p-4.text-center
              | 🏞️
              h5.mt-3.fw-bold Lago Calafquén
              p.text-muted Uno de los lagos más visitados de la zona, ideal para deportes náuticos y playas familiares
              .small.text-muted 📍 Lican Ray

        .col-md-4
          .card.h-100.border-0.shadow-sm
            .card-body.p-4.text-center
              | 🌋
              h5.mt-3.fw-bold Termas Geométricas
              p.text-muted Famosas termas con arquitectura única y piscinas termales rodeadas de naturaleza
              .small.text-muted 📍 Coñaripe

        .col-md-4
          .card.h-100.border-0.shadow-sm
            .card-body.p-4.text-center
              | 🌲
              h5.mt-3.fw-bold Parque Nacional Villarrica
              p.text-muted Senderos, volcanes y bosques nativos. Uno de los parques más visitados del sur de Chile
              .small.text-muted 📍 Cercano a Coñaripe y Lican Ray

  //- Pricing Section
  section.py-5.bg-light
    .container
      .row
        .col-lg-8.mx-auto.text-center
          h2.display-6.fw-bold.mb-4 
            | Condiciones
          
          .pricing-info.p-4.rounded.mb-4
              

            .row.g-3.text-start
              .col-md-6
                h6.fw-bold 
                  | ✅ Incluido:
                ul.list-unstyled.small
                  li • Ropa de cama
                  li • Wi-Fi gratuito
                  li • Estacionamiento
                  li • Uso de parrilla
                  li • Calefacción a leña
              
              .col-md-6
                h6.fw-bold 
                  | ℹ️ Políticas:
                ul.list-unstyled.small
                  li • Check-in: 15:00 hrs
                  li • Check-out: 11:00 hrs
                  li • No se permiten mascotas
                  li • No fumar en interiores
                  li • Máximo 6 personas

  //- CTA Section
  section.py-5.bg-primary.text-white
    .container.text-center
      h2.display-6.fw-bold.mb-4 
        | 🌟 ¿Te Gusta lo que Ves?
      p.lead.mb-4 Reserva ahora y vive una experiencia inolvidable en nuestra cabaña rodeada de naturaleza
      .d-flex.justify-content-center.gap-3.flex-wrap
        a.btn.btn-warning.btn-lg(href='/reservar') 
          | 📅 Reservar Ahora
        a.btn.btn-outline-light.btn-lg(href='/') 
          | 🏠 Volver al Inicio

block scripts
  script.
    document.addEventListener('DOMContentLoaded', function() {
      // Add scroll animations
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }
        });
      }, observerOptions);

      // Observe all cards and gallery items
      document.querySelectorAll('.feature-card, .gallery-item, .activity-card, .card').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        observer.observe(el);
      });

      // Add hover effects to spec rows
      document.querySelectorAll('.spec-row').forEach(row => {
        row.addEventListener('mouseenter', function() {
          this.style.backgroundColor = 'rgba(45, 80, 22, 0.05)';
          this.style.paddingLeft = '1rem';
        });
        
        row.addEventListener('mouseleave', function() {
          this.style.backgroundColor = '';
          this.style.paddingLeft = '';
        });
      });
    });
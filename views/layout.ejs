<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <%- typeof extraStyles !== 'undefined' ? extraStyles : '' %>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top">
    <div class="container">
      <a class="navbar-brand" href="/">
        <strong>Cabaña Pino Huacho</strong>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Inicio</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/caracteristicas">Características</a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-warning text-dark px-3 mx-2" href="/reservar">Reservar Ahora</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <%- body %>
  </main>

  <footer class="bg-dark text-light py-5 mt-5">
    <div class="container">
      <div class="row">
        <div class="col-md-4">
          <h5>Cabaña Pino Huacho</h5>
          <p>Descanso natural en el corazón de la Araucanía. Ubicada en un entorno privilegiado rodeado de bosques nativos.</p>
        </div>

        <div class="col-md-4">
          <h5>Contacto</h5>
          <p>
            Email: info@pinohuacho.cl<br>
            Teléfono: +56 9 1234 5678<br>
            Dirección: Pino Huacho, IX Región
          </p>
        </div>

        <div class="col-md-4">
          <h5>Síguenos</h5>
          <div class="social-links">
            <a class="text-light me-3" href="#">Facebook</a>
            <a class="text-light me-3" href="#">Instagram</a>
            <a class="text-light" href="#">WhatsApp</a>
          </div>
        </div>
      </div>

      <hr class="my-4">
      <div class="text-center">
        <p>&copy; 2024 Cabaña Pino Huacho. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <%- typeof extraScripts !== 'undefined' ? extraScripts : '' %>
</body>
</html>

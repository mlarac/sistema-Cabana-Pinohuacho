extends layout

block content
  section.py-5.mt-5
    .container
      .row.justify-content-center
        .col-lg-8.text-center
          .card.shadow-lg
            .card-body.p-5
              .success-icon.mb-4
                | ✅

              h1.display-5.fw-bold.text-success.mb-4 
                | 🎉 ¡Reserva Confirmada!
              
              p.lead.mb-4 Tu reserva ha sido procesada exitosamente. Hemos enviado un email de confirmación a tu dirección de correo con todos los detalles.

              .reservation-details.bg-light.p-4.rounded.mb-4
                h4.fw-bold.mb-3 
                  | 📋 Detalles de tu Reserva
                
                .row.g-3
                  .col-md-6
                    .detail-item
                      strong 
                        | 👤 Huésped:
                      p.mb-0= reservation.guestName
                  
                  .col-md-6
                    .detail-item
                      strong 
                        | ✉️ Email:
                      p.mb-0= reservation.guestEmail
                  
                  .col-md-6
                    .detail-item
                      strong 
                        | 📞 Teléfono:
                      p.mb-0= reservation.guestPhone
                  
                  .col-md-6
                    .detail-item
                      strong 
                        | 👥 Huéspedes:
                      p.mb-0= reservation.guests + (reservation.guests === 1 ? ' persona' : ' personas')
                  
                  .col-md-6
                    .detail-item
                      strong 
                        | 📅 Check-in:
                      p.mb-0= reservation.checkIn
                  
                  .col-md-6
                    .detail-item
                      strong 
                        | 📅 Check-out:
                      p.mb-0= reservation.checkOut
                
                hr.my-3
                
                .text-center
                  h5.fw-bold 
                    | 💰 Total Pagado: #{reservation.totalPrice}

              .next-steps.mb-4
                h4.fw-bold.mb-3 
                  | 🎯 Próximos Pasos
                .row.g-3
                  .col-md-4
                    .step-card.p-3.border.rounded.h-100
                      | ✉️
                      h6.mt-2.fw-bold Revisa tu Email
                      p.small Encontrarás todos los detalles de tu reserva y las instrucciones
                  
                  .col-md-4
                    .step-card.p-3.border.rounded.h-100
                      | 🗺️
                      h6.mt-2.fw-bold Planifica tu Viaje
                      p.small Te enviaremos las indicaciones exactas para llegar
                  
                  .col-md-4
                    .step-card.p-3.border.rounded.h-100
                      | ❤️
                      h6.mt-2.fw-bold ¡Disfruta!
                      p.small Relájate y conecta con la naturaleza en Pino Huacho

              .action-buttons
                a.btn.btn-primary.btn-lg.me-3(href='/') 
                  | 🏠 Volver al Inicio
                a.btn.btn-outline-primary.btn-lg(href='/caracteristicas') 
                  | 📋 Ver Características

  section.py-5.bg-light
    .container
      .row.justify-content-center
        .col-lg-8.text-center
          h3.fw-bold.mb-4 
            | ℹ️ Información Importante
          
          .row.g-4
            .col-md-6
              .info-card.p-4.border.rounded.bg-white.h-100
                | 🕐
                h5.mt-3.fw-bold Horarios
                p 
                  strong Check-in: 
                  | 15:00 hrs
                p.mb-0 
                  strong Check-out: 
                  | 11:00 hrs
            
            .col-md-6
              .info-card.p-4.border.rounded.bg-white.h-100
                | 📞
                h5.mt-3.fw-bold Contacto
                p 
                  strong Teléfono: 
                  | +56 9 1234 5678
                p.mb-0 
                  strong Email: 
                  | info@pinohuacho.cl

          .row.g-4.mt-2
            .col-md-6
              .info-card.p-4.border.rounded.bg-white.h-100
                | 🎒
                h5.mt-3.fw-bold Qué Traer
                ul.list-unstyled.text-start.small
                  li • Ropa abrigada
                  li • Calzado para caminar
                  li • Protector solar
                  li • Cámara fotográfica
            
            .col-md-6
              .info-card.p-4.border.rounded.bg-white.h-100
                | 📋
                h5.mt-3.fw-bold Incluido
                ul.list-unstyled.text-start.small
                  li • Ropa de cama y toallas
                  li • Wi-Fi gratuito
                  li • Estacionamiento
                  li • Uso de parrilla

          .mt-4
            .alert.alert-info
              | ℹ️
              strong.ms-2 Nota Importante: 
              | Si tienes alguna consulta o necesitas modificar tu reserva, no dudes en contactarnos. 
              | Te responderemos a la brevedad para asegurar que tengas la mejor experiencia posible.

  //- Weather and Tips Section
  section.py-5
    .container
      .row.justify-content-center
        .col-lg-8
          .card.border-0.shadow-sm
            .card-body.p-4
              h4.fw-bold.mb-4.text-center 
                | 🌤️ Consejos para tu Estadía
              
              .row.g-4
                .col-md-6
                  h6.fw-bold 
                    | 🌡️ Clima en la Araucanía
                  p.small La región tiene un clima templado lluvioso. Te recomendamos traer ropa impermeable y abrigada, especialmente en invierno (junio-agosto).
                
                .col-md-6
                  h6.fw-bold 
                    | 🛒 Compras Cercanas
                  p.small El pueblo más cercano está a 15 minutos en auto. Recomendamos traer provisiones básicas o hacer compras antes de llegar.
                
                .col-md-6
                  h6.fw-bold 
                    | 🚗 Acceso a la Cabaña
                  p.small El camino es transitable todo el año. Los últimos 2 km son de ripio en buen estado. Cualquier vehículo puede acceder sin problemas.
                
                .col-md-6
                  h6.fw-bold 
                    | 📱 Conectividad
                  p.small Hay cobertura móvil y Wi-Fi disponible. Perfecto para compartir tus fotos de la naturaleza o trabajar remotamente si es necesario.

block scripts
  script.
    document.addEventListener('DOMContentLoaded', function() {
      // Add celebration animation
      const successIcon = document.querySelector('.success-icon');
      if (successIcon) {
        successIcon.style.fontSize = '4rem';
        successIcon.style.animation = 'bounce 2s infinite';
      }

      // Add scroll animations
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }
        });
      }, observerOptions);

      document.querySelectorAll('.step-card, .info-card').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        observer.observe(el);
      });
    });

  style.
    @keyframes bounce {
      0%, 20%, 50%, 80%, 100% {
        transform: translateY(0);
      }
      40% {
        transform: translateY(-10px);
      }
      60% {
        transform: translateY(-5px);
      }
    }
    
    .success-icon {
      font-size: 4rem;
      animation: bounce 2s infinite;
    }
    
    .detail-item strong {
      color: var(--primary-color);
    }
    
    .step-card, .info-card {
      transition: all 0.3s ease;
    }
    
    .step-card:hover, .info-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
    }
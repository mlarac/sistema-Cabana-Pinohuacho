<% extraStyles = '<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">' %>

<section class="py-5 mt-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6 text-center">
        <div class="error-container py-5">
          <div class="error-icon mb-4">
            <i class="fas fa-exclamation-triangle fa-5x text-warning"></i>
          </div>

          <h1 class="display-4 fw-bold text-dark mb-3"><%= title %></h1>

          <p class="lead text-muted mb-4"><%= message %></p>

          <div class="action-buttons">
            <a class="btn btn-primary btn-lg me-3" href="/">Volver al Inicio</a>
            <a class="btn btn-outline-primary btn-lg" href="javascript:history.back()">Ir Atrás</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

        <h1 class="display-4 fw-bold">🏠 Características de la Cabaña</h1>
        <p class="lead">Descubre todo lo que nuestra cabaña tiene para ofrecerte en el corazón de la Araucanía</p>
      </div>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row g-4">
      <% features.forEach(function(feature) { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm feature-card">
          <div class="card-body text-center p-4">
            <div class="feature-icon mb-4">
              <% if (feature.icon === 'home') { %>🏠
              <% } else if (feature.icon === 'wifi') { %>📶
              <% } else if (feature.icon === 'car') { %>🚗
              <% } else if (feature.icon === 'flame') { %>🔥
              <% } else if (feature.icon === 'utensils') { %>🍽️
              <% } else if (feature.icon === 'tree-pine') { %>🌲
              <% } else { %>✨<% } %>
            </div>
            <h5 class="card-title fw-bold"><%= feature.title %></h5>
            <p class="card-text"><%= feature.description %></p>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>


extends layout

block content
  //- Hero Section
  section.hero-section
    .hero-overlay
    .container.h-100
      .row.h-100.align-items-center
        .col-lg-8
          .hero-content.text-white
            h1.display-4.fw-bold.mb-4 
              | 🌲 Descanso Natural en el Corazón de la Araucanía
            p.lead.mb-4 Escapa de la rutina y conecta con la naturaleza en nuestra acogedora cabaña ubicada en Pino Huacho. Un refugio perfecto para relajarse y disfrutar de paisajes únicos rodeados de bosques nativos y lagos cristalinos.
            .hero-buttons
              a.btn.btn-warning.btn-lg.me-3(href='/reservar') 
                | 📅 Reservar Ahora
              a.btn.btn-outline-light.btn-lg(href='/caracteristicas') 
                | 🏠 Ver Características

  //- Quick Info Section
  section.py-5.bg-light
    .container
      .row.text-center.g-4
        .col-md-3
          .feature-card.p-4.h-100
            .feature-icon.mb-3
              | 👥
            h5.fw-bold Hasta 5 personas
            p.text-muted Espaciosa y cómoda para grupos familiares y amigos
        
        .col-md-3
          .feature-card.p-4.h-100
            .feature-icon.mb-3
              | 🛏️
            h5.fw-bold 2 Habitaciones
            p.text-muted Dormitorios acogedores con ropa de cama incluida
        
        .col-md-3
          .feature-card.p-4.h-100
            .feature-icon.mb-3
              | 🔥
            h5.fw-bold Calefacción a leña
            p.text-muted Ambiente cálido y acogedor durante todo el año
        
        .col-md-3
          .feature-card.p-4.h-100
            .feature-icon.mb-3
              | 🌲
            h5.fw-bold Entorno natural
            p.text-muted Rodeada de bosques nativos y senderos para explorar

  //- Availability Calendar Section
  section.py-5
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-5.fw-bold 
            | 📅 Disponibilidad en Tiempo Real
          p.lead Consulta las fechas disponibles y planifica tu estadía perfecta

      .row.justify-content-center
        .col-lg-10
          .card.shadow-lg.border-0
            .card-header.text-white.text-center.py-4
              .d-flex.justify-content-between.align-items-center
                button.btn.btn-outline-light(onclick='changeMonth(-1)')
                  | ← Anterior
                h4.mb-0#calendar-title
                  | 📅 Cargando...
                button.btn.btn-outline-light(onclick='changeMonth(1)')
                  | Siguiente →

            .card-body.p-4
              //- Calendar Legend
              .row.mb-4
                .col-12
                  .d-flex.justify-content-center.flex-wrap.gap-4
                    .legend-item.d-flex.align-items-center
                      .legend-color.available.me-2
                      span 🟢 Disponible
                    .legend-item.d-flex.align-items-center
                      .legend-color.occupied.me-2
                      span 🔴 Ocupado
                    .legend-item.d-flex.align-items-center
                      .legend-color.maintenance.me-2
                      span 🟡 Mantenimiento
                    .legend-item.d-flex.align-items-center
                      .legend-color.selected.me-2
                      span 🔵 Seleccionado

              //- Calendar Container
              #availability-calendar.calendar-grid
                .text-center.py-5
                  .spinner-border.text-primary(role='status')
                    span.visually-hidden Cargando calendario...

              //- Selected Dates Info
              #selected-dates-info.mt-4(style='display: none;')
                .alert.alert-info
                  h6.fw-bold.mb-2 
                    | 📋 Fechas Seleccionadas
                  .row
                    .col-md-4
                      strong 📅 Entrada: 
                      span#selected-checkin -
                    .col-md-4
                      strong 📅 Salida: 
                      span#selected-checkout -
                    .col-md-4
                      strong 🌙 Noches: 
                      span#selected-nights -
                  .mt-3
                    strong 💰 Precio estimado: 
                    span#estimated-price $0 CLP
                  .mt-3.text-center
                    a.btn.btn-success.btn-lg(href='/reservar', id='reserve-btn')
                      | ✅ Reservar estas fechas

  //- Gallery Preview Section
  section.py-5.bg-light
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-5.fw-bold 
            | 🏞️ Un Lugar Único para Descansar
          p.lead Descubre la belleza natural de la Araucanía desde nuestra cabaña
      
      .row.g-4
        .col-md-6
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='./img/balcon.jpg', alt='Interior acogedor de la cabaña')
            .gallery-overlay
              h5 
                | 🏠 Interior Acogedor
              p Espacios cálidos y confortables con decoración rústica
        
        .col-md-6
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='./img/portada.jpg', alt='Vista exterior de la cabaña')
            .gallery-overlay
              h5 
                | 🌲 Arquitectura Natural
              p Perfecta integración con el entorno boscoso
        
        .col-md-6
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='./img/comedor.png', alt='Cocina equipada')
            .gallery-overlay
              h5 
                | 🍽️ Cocina Completamente Equipada
              p Todo lo necesario para preparar deliciosas comidas
        
        .col-md-6
          .gallery-item.position-relative.overflow-hidden.rounded-3
            img.img-fluid.gallery-img(src='./img/paisaje.png', alt='Paisaje natural circundante')
            .gallery-overlay
              h5 
                | 🏔️ Paisajes Únicos
              p Naturaleza virgen y vistas panorámicas a tu alrededor

  //- Google Maps Section
  section.py-5.bg-white
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-6.fw-bold
            | 📍 ¿Dónde estamos?
          p.lead Encuentra nuestra cabaña en el corazón de la Araucanía
      .row.justify-content-center
        .col-lg-10.text-center
          img.img-fluid.rounded-3.shadow(src='./img/mapa.png', alt='Ubicación de la cabaña en el mapa')

  //- Features Highlight
  section.py-5
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-6.fw-bold 
            | ✨ Comodidades Premium
          p.lead Todo lo que necesitas para una estadía perfecta

      .row.g-4
        .col-md-4
          .feature-card.text-center.p-4.h-100
            .feature-icon.mb-3
              | 📶
            h5.fw-bold Wi-Fi Gratuito
            p.text-muted Internet de alta velocidad para mantenerte conectado
        
        .col-md-4
          .feature-card.text-center.p-4.h-100
            .feature-icon.mb-3
              | 🚗
            h5.fw-bold Estacionamiento
            p.text-muted Espacio privado y seguro para tu vehículo
        
        .col-md-4
          .feature-card.text-center.p-4.h-100
            .feature-icon.mb-3
              | 🔥
            h5.fw-bold Parrilla
            p.text-muted Disfruta de asados al aire libre con vista al bosque

  //- Activities Section
  section.py-5.bg-light
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-6.fw-bold 
            | 🎯 Actividades y Experiencias
          p.lead Descubre todo lo que puedes hacer en Pino Huacho

      .row.g-4
        .col-md-6.col-lg-3
          .activity-card.text-center.p-4.h-100
            | 🥾
            h5.mt-3.fw-bold Senderismo
            p.text-muted Rutas de diferentes niveles por bosques nativos

        .col-md-6.col-lg-3
          .activity-card.text-center.p-4.h-100
            | 📸
            h5.mt-3.fw-bold Fotografía
            p.text-muted Paisajes únicos ideales para capturar momentos

        .col-md-6.col-lg-3
          .activity-card.text-center.p-4.h-100
            | 🎣
            h5.mt-3.fw-bold Pesca
            p.text-muted Lagos y ríos cercanos para la pesca deportiva

        .col-md-6.col-lg-3
          .activity-card.text-center.p-4.h-100
            | 🍃
            h5.mt-3.fw-bold Observación
            p.text-muted Flora y fauna nativa de la Araucanía

  //- Testimonials Section
  section.py-5
    .container
      .row
        .col-12.text-center.mb-5
          h2.display-6.fw-bold 
            | 💬 Lo que dicen nuestros huéspedes
          p.lead Experiencias reales de quienes nos han visitado

      .row.g-4
        .col-md-4
          .card.h-100.border-0.shadow-sm
            .card-body.p-4.text-center
              | ⭐⭐⭐⭐⭐
              p.mt-3.mb-3 "Una experiencia increíble. La cabaña es exactamente como se ve en las fotos, muy acogedora y con todas las comodidades."
              strong - María González

        .col-md-4
          .card.h-100.border-0.shadow-sm
            .card-body.p-4.text-center
              | ⭐⭐⭐⭐⭐
              p.mt-3.mb-3 "El lugar perfecto para desconectarse. Los paisajes son espectaculares y la atención es excelente."
              strong - Carlos Mendoza

        .col-md-4
          .card.h-100.border-0.shadow-sm
            .card-body.p-4.text-center
              | ⭐⭐⭐⭐⭐
              p.mt-3.mb-3 "Ideal para ir en familia. Los niños disfrutaron mucho y nosotros pudimos relajarnos completamente."
              strong - Ana Rodríguez

  //- CTA Section
  section.py-5.bg-primary.text-white
    .container.text-center
      .row
        .col-lg-8.mx-auto
          h2.display-5.fw-bold.mb-4 
            | 🌟 ¿Listo para una Experiencia Única?
          p.lead.mb-4 Reserva ahora y asegura tu lugar en este paraíso natural. Disponibilidad limitada durante temporada alta.
          .d-flex.justify-content-center.gap-3.flex-wrap
            a.btn.btn-warning.btn-lg(href='/reservar') 
              | 📅 Hacer Reserva
            a.btn.btn-outline-light.btn-lg(href='/caracteristicas') 
              | 📋 Ver Detalles

block scripts  
  link(rel='stylesheet', href='/css/index.css')
  script(src='/js/index.js')

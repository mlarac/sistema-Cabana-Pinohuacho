extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1.display-6.fw-bold Gestión de Reservas
    .text-muted= reservations.length + ' reservas encontradas'

  .card.border-0.shadow-sm
    .card-body.p-0
      if reservations && reservations.length > 0
        .table-responsive
          table.table.table-hover.mb-0
            thead.bg-light
              tr
                th.px-4.py-3 ID
                th.py-3 Huésped
                th.py-3 Contacto
                th.py-3 Fechas
                th.py-3 Huéspedes
                th.py-3 Estado
                th.py-3.text-end Total
                th.py-3.text-center Acciones
            tbody
              each reservation in reservations
                tr(id=`reservation-${reservation.id}`)
                  td.px-4.py-3
                    .fw-bold ##{reservation.id}
                    .small.text-muted= reservation.createdAt
                  
                  td.py-3
                    .fw-bold= reservation.guestName
                    if reservation.notes
                      .small.text-muted
                        i.fas.fa-sticky-note.me-1
                        = reservation.notes.substring(0, 30) + (reservation.notes.length > 30 ? '...' : '')
                  
                  td.py-3
                    .small
                      div
                        i.fas.fa-envelope.me-1
                        = reservation.guestEmail
                      div
                        i.fas.fa-phone.me-1  
                        = reservation.guestPhone
                  
                  td.py-3
                    .small
                      .fw-bold= reservation.checkIn
                      | → #{reservation.checkOut}
                  
                  td.py-3
                    span.badge.bg-light.text-dark= reservation.guests + (reservation.guests === 1 ? ' persona' : ' personas')
                  
                  td.py-3
                    case reservation.status
                      when 'confirmed'
                        span.badge.bg-success Confirmada
                      when 'pending'
                        span.badge.bg-warning Pendiente
                      when 'cancelled'
                        span.badge.bg-danger Cancelada
                      default
                        span.badge.bg-secondary= reservation.status
                  
                  td.py-3.text-end
                    .fw-bold= reservation.totalPrice
                  
                  td.py-3.text-center
                    if reservation.status !== 'cancelled'
                      button.btn.btn-outline-danger.btn-sm(onclick=`cancelReservation(${reservation.id})`)
                        i.fas.fa-times.me-1
                        | Cancelar
                    else
                      span.text-muted Cancelada
      else
        .text-center.py-5
          i.fas.fa-inbox.fa-4x.text-muted.mb-4
          h4.text-muted No hay reservas registradas
          p.text-muted Cuando recibas reservas, aparecerán aquí.

  //- Pagination
  if pagination && pagination.totalPages > 1
    nav.mt-4
      ul.pagination.justify-content-center
        if pagination.hasPrev
          li.page-item
            a.page-link(href='?page=' + (pagination.currentPage - 1)) Anterior
        
        - for (let i = 1; i <= pagination.totalPages; i++)
          li.page-item(class=pagination.currentPage === i ? 'active' : '')
            a.page-link(href='?page=' + i)= i
        
        if pagination.hasNext
          li.page-item
            a.page-link(href='?page=' + (pagination.currentPage + 1)) Siguiente

block scripts
  script.
    function cancelReservation(reservationId) {
      if (!confirm('¿Estás seguro de que quieres cancelar esta reserva?')) {
        return;
      }

      fetch(`/admin/reservas/${reservationId}/cancel`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Update the row to show cancelled status
          const row = document.getElementById(`reservation-${reservationId}`);
          const statusCell = row.querySelector('td:nth-child(6)');
          const actionCell = row.querySelector('td:nth-child(8)');
          
          statusCell.innerHTML = '<span class="badge bg-danger">Cancelada</span>';
          actionCell.innerHTML = '<span class="text-muted">Cancelada</span>';
          
          // Show success message
          showAlert('success', data.message);
        } else {
          showAlert('danger', data.error || 'Error al cancelar la reserva');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        showAlert('danger', 'Error de conexión');
      });
    }

    function showAlert(type, message) {
      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
      alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      `;
      
      const container = document.querySelector('main');
      container.insertBefore(alertDiv, container.firstChild);
      
      // Auto-remove after 5 seconds
      setTimeout(() => {
        alertDiv.remove();
      }, 5000);
    }
doctype html
html(lang='es')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= title
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css', rel='stylesheet')
    link(href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap', rel='stylesheet')
    style.
      body {
        font-family: 'Poppins', sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .login-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: none;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
      }
      .brand-logo {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
      }

  body
    .container
      .row.justify-content-center
        .col-md-6.col-lg-4
          .card.login-card.shadow-lg
            .card-body.p-5
              .text-center.mb-4
                .brand-logo
                  i.fas.fa-home.fa-2x.text-white
                h2.fw-bold.mb-0 Panel de Admin
                p.text-muted Cabaña Pino Huacho

              if errors && errors.length > 0
                .alert.alert-danger
                  ul.mb-0
                    each error in errors
                      li= error.msg

              form(method='POST', action='/admin/login')
                .mb-3
                  label.form-label(for='username') Usuario
                  .input-group
                    span.input-group-text
                      i.fas.fa-user
                    input.form-control(type='text', id='username', name='username', 
                      value=formData ? formData.username : '', required, 
                      placeholder='Ingresa tu usuario')

                .mb-4
                  label.form-label(for='password') Contraseña
                  .input-group
                    span.input-group-text
                      i.fas.fa-lock
                    input.form-control(type='password', id='password', name='password', 
                      required, placeholder='Ingresa tu contraseña')

                button.btn.btn-primary.w-100.py-2.fw-bold(type='submit')
                  i.fas.fa-sign-in-alt.me-2
                  | Iniciar Sesión

              .text-center.mt-4
                a.text-decoration-none(href='/')
                  i.fas.fa-arrow-left.me-2
                  | Volver al sitio web

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css')
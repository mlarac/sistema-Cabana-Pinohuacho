extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1.display-6.fw-bold Calendario de Disponibilidad
    .d-flex.gap-2
      button.btn.btn-primary(onclick='showAvailabilityModal()') Actualizar Disponibilidad
      select.form-select(id='monthSelector', style='width: auto;')
        - for (let i = 0; i < 12; i++)
          - const date = new Date(); date.setMonth(i)
          option(value=i, selected=i === new Date().getMonth())= date.toLocaleDateString('es-CL', { month: 'long', year: 'numeric' })

  //- Legend
  .card.border-0.shadow-sm.mb-4
    .card-body.py-3
      .row.text-center
        .col-auto
          .d-flex.align-items-center
            .calendar-legend.bg-success.me-2
            span Disponible
        .col-auto
          .d-flex.align-items-center
            .calendar-legend.bg-danger.me-2
            span Ocupado
        .col-auto
          .d-flex.align-items-center
            .calendar-legend.bg-warning.me-2
            span Mantenimiento
        .col-auto
          .d-flex.align-items-center
            .calendar-legend.border.border-2.border-primary.me-2
            span Seleccionado

  //- Calendar Container
  .card.border-0.shadow-sm
    .card-body
      #calendar-container.text-center
        .spinner-border.text-primary(role='status')
          span.visually-hidden Cargando calendario...

  //- Availability Modal
  .modal.fade#availabilityModal(tabindex='-1')
    .modal-dialog
      .modal-content
        .modal-header
          h5.modal-title Actualizar Disponibilidad
          button.btn-close(data-bs-dismiss='modal')
        
        .modal-body
          form#availabilityForm
            .mb-3
              label.form-label(for='selectedDate') Fecha
              input.form-control(type='date', id='selectedDate', name='date', required, readonly)
            
            .mb-3
              label.form-label(for='status') Estado
              select.form-control(id='status', name='status', required)
                option(value='available') Disponible
                option(value='occupied') Ocupado
                option(value='maintenance') Mantenimiento
            
            .mb-3
              label.form-label(for='notes') Notas (opcional)
              textarea.form-control(id='notes', name='notes', rows='3')
        
        .modal-footer
          button.btn.btn-secondary(data-bs-dismiss='modal') Cancelar
          button.btn.btn-primary(type='submit', form='availabilityForm') Guardar

block scripts
  style.
    .calendar-container {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 1px;
      background-color: #dee2e6;
      border: 1px solid #dee2e6;
    }
    .calendar-header {
      background-color: #f8f9fa;
      padding: 0.75rem;
      font-weight: bold;
      text-align: center;
      border: 1px solid #dee2e6;
    }
    .calendar-day {
      background-color: white;
      padding: 0.75rem;
      min-height: 60px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .calendar-day:hover {
      background-color: #f8f9fa;
    }
    .calendar-day.available {
      background-color: #d4edda;
      color: #155724;
    }
    .calendar-day.occupied {
      background-color: #f8d7da;
      color: #721c24;
    }
    .calendar-day.maintenance {
      background-color: #fff3cd;
      color: #856404;
    }
    .calendar-day.selected {
      border: 2px solid #007bff !important;
      box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }
    .calendar-legend {
      width: 20px;
      height: 20px;
      border-radius: 3px;
    }
    .calendar-day.other-month {
      color: #6c757d;
      background-color: #f8f9fa;
    }

  script.
    let currentMonth = new Date().getMonth();
    let currentYear = new Date().getFullYear();
    let selectedDate = null;
    let availabilityData = {};

    document.addEventListener('DOMContentLoaded', function() {
      loadCalendar();
      
      document.getElementById('monthSelector').addEventListener('change', function() {
        const selectedMonth = parseInt(this.value);
        currentMonth = selectedMonth;
        currentYear = new Date().getFullYear();
        if (selectedMonth < new Date().getMonth()) {
          currentYear++;
        }
        loadCalendar();
      });

      // Handle availability form submission
      document.getElementById('availabilityForm').addEventListener('submit', function(e) {
        e.preventDefault();
        updateAvailability();
      });
    });

    function loadCalendar() {
      fetch(`/api/availability/${currentYear}/${(currentMonth + 1).toString().padStart(2, '0')}`)
        .then(response => response.json())
        .then(data => {
          availabilityData = data;
          renderCalendar();
        })
        .catch(error => {
          console.error('Error loading calendar:', error);
          showAlert('danger', 'Error al cargar el calendario');
        });
    }

    function renderCalendar() {
      const container = document.getElementById('calendar-container');
      const firstDay = new Date(currentYear, currentMonth, 1);
      const lastDay = new Date(currentYear, currentMonth + 1, 0);
      const startDate = new Date(firstDay);
      startDate.setDate(startDate.getDate() - firstDay.getDay());

      let html = '<div class="calendar-container">';
      
      // Headers
      const dayNames = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];
      dayNames.forEach(day => {
        html += `<div class="calendar-header">${day}</div>`;
      });

      // Calendar days
      const current = new Date(startDate);
      for (let week = 0; week < 6; week++) {
        let hasCurrentMonth = false;
        for (let day = 0; day < 7; day++) {
          const dateStr = current.toISOString().split('T')[0];
          const isCurrentMonth = current.getMonth() === currentMonth;
          const status = availabilityData[dateStr] || 'available';
          
          if (isCurrentMonth) hasCurrentMonth = true;

          html += `<div class="calendar-day ${status} ${!isCurrentMonth ? 'other-month' : ''}" 
                        onclick="selectDate('${dateStr}')" 
                        data-date="${dateStr}">
                     ${current.getDate()}
                   </div>`;
          
          current.setDate(current.getDate() + 1);
        }
        if (!hasCurrentMonth && week > 3) break;
      }

      html += '</div>';
      container.innerHTML = html;
    }

    function selectDate(dateStr) {
      // Remove previous selection
      document.querySelectorAll('.calendar-day.selected').forEach(el => {
        el.classList.remove('selected');
      });
      
      // Add selection to clicked date
      document.querySelector(`[data-date="${dateStr}"]`).classList.add('selected');
      
      selectedDate = dateStr;
      document.getElementById('selectedDate').value = dateStr;
      
      // Set current status in modal
      const currentStatus = availabilityData[dateStr] || 'available';
      document.getElementById('status').value = currentStatus;
    }

    function showAvailabilityModal() {
      if (!selectedDate) {
        showAlert('warning', 'Por favor selecciona una fecha primero');
        return;
      }
      
      const modal = new bootstrap.Modal(document.getElementById('availabilityModal'));
      modal.show();
    }

    function updateAvailability() {
      const formData = new FormData(document.getElementById('availabilityForm'));
      const data = Object.fromEntries(formData.entries());

      fetch('/admin/availability', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      })
      .then(response => response.json())
      .then(result => {
        if (result.success) {
          showAlert('success', result.message);
          
          // Update local data and re-render
          availabilityData[data.date] = data.status;
          renderCalendar();
          
          // Close modal
          const modal = bootstrap.Modal.getInstance(document.getElementById('availabilityModal'));
          modal.hide();
          
          // Reset form
          document.getElementById('availabilityForm').reset();
          selectedDate = null;
        } else {
          showAlert('danger', result.error || 'Error al actualizar disponibilidad');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        showAlert('danger', 'Error de conexión');
      });
    }

    function showAlert(type, message) {
      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
      alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      `;
      
      const container = document.querySelector('main');
      container.insertBefore(alertDiv, container.firstChild);
      
      setTimeout(() => {
        alertDiv.remove();
      }, 5000);
    }
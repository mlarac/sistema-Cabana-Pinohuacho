extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1.display-6.fw-bold Panel de Administración
    .text-muted
      i.fas.fa-calendar.me-2
      = new Date().toLocaleDateString('es-CL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })

  //- Statistics Cards
  .row.g-4.mb-5
    .col-md-6.col-xl-3
      .card.border-0.shadow-sm.h-100
        .card-body.p-4
          .d-flex.align-items-center
            .stat-icon.bg-primary.text-white.rounded-3.p-3.me-3
              i.fas.fa-calendar-check.fa-2x
            div
              h3.fw-bold.mb-0= stats.totalReservations
              p.text-muted.mb-0 Total Reservas

    .col-md-6.col-xl-3
      .card.border-0.shadow-sm.h-100
        .card-body.p-4
          .d-flex.align-items-center
            .stat-icon.bg-warning.text-white.rounded-3.p-3.me-3
              i.fas.fa-clock.fa-2x
            div
              h3.fw-bold.mb-0= stats.pendingReservations
              p.text-muted.mb-0 Pendientes

    .col-md-6.col-xl-3
      .card.border-0.shadow-sm.h-100
        .card-body.p-4
          .d-flex.align-items-center
            .stat-icon.bg-success.text-white.rounded-3.p-3.me-3
              i.fas.fa-chart-line.fa-2x
            div
              h3.fw-bold.mb-0= stats.thisMonthReservations
              p.text-muted.mb-0 Este Mes

    .col-md-6.col-xl-3
      .card.border-0.shadow-sm.h-100
        .card-body.p-4
          .d-flex.align-items-center
            .stat-icon.bg-info.text-white.rounded-3.p-3.me-3
              i.fas.fa-dollar-sign.fa-2x
            div
              h3.fw-bold.mb-0= stats.thisMonthRevenue
              p.text-muted.mb-0 Ingresos del Mes

  .row.g-4
    //- Recent Reservations
    .col-lg-7
      .card.border-0.shadow-sm.h-100
        .card-header.bg-white.border-bottom-0.py-3
          .d-flex.justify-content-between.align-items-center
            h5.fw-bold.mb-0
              i.fas.fa-calendar-alt.me-2
              | Próximas Reservas
            a.btn.btn-outline-primary.btn-sm(href='/admin/reservas') Ver Todas

        .card-body.p-0
          if recentReservations && recentReservations.length > 0
            .table-responsive
              table.table.table-hover.mb-0
                thead.bg-light
                  tr
                    th.px-4.py-3 Huésped
                    th.py-3 Fechas
                    th.py-3 Huéspedes
                    th.py-3.text-end Total
                tbody
                  each reservation in recentReservations
                    tr
                      td.px-4.py-3
                        .fw-bold= reservation.guestName
                        .small.text-muted= reservation.guestEmail
                      td.py-3
                        .small
                          strong= reservation.checkIn
                          | &nbsp;→&nbsp;
                          = reservation.checkOut
                      td.py-3
                        span.badge.bg-light.text-dark= reservation.guests
                      td.py-3.text-end
                        .fw-bold= reservation.totalPrice
          else
            .text-center.py-5
              i.fas.fa-calendar-times.fa-3x.text-muted.mb-3
              p.text-muted No hay reservas próximas

    //- Quick Actions
    .col-lg-5
      .card.border-0.shadow-sm.h-100
        .card-header.bg-white.border-bottom-0.py-3
          h5.fw-bold.mb-0
            i.fas.fa-bolt.me-2
            | Acciones Rápidas

        .card-body.p-4
          .d-grid.gap-3
            a.btn.btn-primary.btn-lg.text-start(href='/admin/reservas')
              .d-flex.align-items-center
                i.fas.fa-list.fa-2x.me-3
                div
                  .fw-bold Gestionar Reservas
                  .small Ver, editar y cancelar reservas

            a.btn.btn-success.btn-lg.text-start(href='/admin/calendario')
              .d-flex.align-items-center
                i.fas.fa-calendar.fa-2x.me-3
                div
                  .fw-bold Calendario
                  .small Gestionar disponibilidad por fechas

            a.btn.btn-info.btn-lg.text-start(href='/', target='_blank')
              .d-flex.align-items-center
                i.fas.fa-eye.fa-2x.me-3
                div
                  .fw-bold Vista del Sitio
                  .small Ver cómo lo ven los clientes

block scripts
  script.
    // Add any dashboard-specific scripts here
    document.addEventListener('DOMContentLoaded', function() {
      // Auto-refresh dashboard every 5 minutes
      setTimeout(function() {
        window.location.reload();
      }, 300000);
    });
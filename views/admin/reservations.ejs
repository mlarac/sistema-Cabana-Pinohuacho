<% extraScripts = `
<script>
  function cancelReservation(reservationId) {
    if (!confirm('¿Estás seguro de que quieres cancelar esta reserva?')) {
      return;
    }

    fetch('/admin/reservas/' + reservationId + '/cancel', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        const row = document.getElementById('reservation-' + reservationId);
        const statusCell = row.querySelector('td:nth-child(6)');
        const actionCell = row.querySelector('td:nth-child(8)');
        statusCell.innerHTML = '<span class="badge bg-danger">Cancelada</span>';
        actionCell.innerHTML = '<span class="text-muted">Cancelada</span>';
        showAlert('success', data.message);
      } else {
        showAlert('danger', data.error || 'Error al cancelar la reserva');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      showAlert('danger', 'Error de conexión');
    });
  }

  function showAlert(type, message) {
    const alertDiv = document.createElement('div');
    alertDiv.className = 'alert alert-' + type + ' alert-dismissible fade show';
    alertDiv.innerHTML = message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    const container = document.querySelector('main');
    container.insertBefore(alertDiv, container.firstChild);
    setTimeout(() => { alertDiv.remove(); }, 5000);
  }
</script>
` %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="display-6 fw-bold">Gestión de Reservas</h1>
  <div class="text-muted"><%= reservations.length %> reservas encontradas</div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if (reservations && reservations.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th class="px-4 py-3">ID</th>
            <th class="py-3">Huésped</th>
            <th class="py-3">Contacto</th>
            <th class="py-3">Fechas</th>
            <th class="py-3">Huéspedes</th>
            <th class="py-3">Estado</th>
            <th class="py-3 text-end">Total</th>
            <th class="py-3 text-center">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% reservations.forEach(function(reservation) { %>
          <tr id="reservation-<%= reservation.id %>">
            <td class="px-4 py-3">
              <div class="fw-bold">#<%= reservation.id %></div>
              <div class="small text-muted"><%= reservation.createdAt %></div>
            </td>

            <td class="py-3">
              <div class="fw-bold"><%= reservation.guestName %></div>
              <% if (reservation.notes) { %>
              <div class="small text-muted">
                <i class="fas fa-sticky-note me-1"></i>
                <%= reservation.notes.substring(0, 30) + (reservation.notes.length > 30 ? '...' : '') %>
              </div>
              <% } %>
            </td>

            <td class="py-3">
              <div class="small">
                <div>
                  <i class="fas fa-envelope me-1"></i>
                  <%= reservation.guestEmail %>
                </div>
                <div>
                  <i class="fas fa-phone me-1"></i>
                  <%= reservation.guestPhone %>
                </div>
              </div>
            </td>

            <td class="py-3">
              <div class="small">
                <div class="fw-bold"><%= reservation.checkIn %></div>
                → <%= reservation.checkOut %>
              </div>
            </td>

            <td class="py-3">
              <span class="badge bg-light text-dark"><%= reservation.guests + (reservation.guests === 1 ? ' persona' : ' personas') %></span>
            </td>

            <td class="py-3">
              <% if (reservation.status === 'confirmed') { %>
              <span class="badge bg-success">Confirmada</span>
              <% } else if (reservation.status === 'pending') { %>
              <span class="badge bg-warning">Pendiente</span>
              <% } else if (reservation.status === 'cancelled') { %>
              <span class="badge bg-danger">Cancelada</span>
              <% } else { %>
              <span class="badge bg-secondary"><%= reservation.status %></span>
              <% } %>
            </td>

            <td class="py-3 text-end">
              <div class="fw-bold"><%= reservation.totalPrice %></div>
            </td>

            <td class="py-3 text-center">
              <% if (reservation.status !== 'cancelled') { %>
              <button class="btn btn-outline-danger btn-sm" onclick="cancelReservation(<%= reservation.id %>)">
                <i class="fas fa-times me-1"></i>
                Cancelar
              </button>
              <% } else { %>
              <span class="text-muted">Cancelada</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="text-center py-5">
      <i class="fas fa-inbox fa-4x text-muted mb-4"></i>
      <h4 class="text-muted">No hay reservas registradas</h4>
      <p class="text-muted">Cuando recibas reservas, aparecerán aquí.</p>
    </div>
    <% } %>
  </div>
</div>

<!-- Pagination -->
<% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
<nav class="mt-4">
  <ul class="pagination justify-content-center">
    <% if (pagination.hasPrev) { %>
    <li class="page-item">
      <a class="page-link" href="?page=<%= pagination.currentPage - 1 %>">Anterior</a>
    </li>
    <% } %>

    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
    <li class="page-item <%= pagination.currentPage === i ? 'active' : '' %>">
      <a class="page-link" href="?page=<%= i %>"><%= i %></a>
    </li>
    <% } %>

    <% if (pagination.hasNext) { %>
    <li class="page-item">
      <a class="page-link" href="?page=<%= pagination.currentPage + 1 %>">Siguiente</a>
    </li>
    <% } %>
  </ul>
</nav>
<% } %>

doctype html
html(lang='es')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= title
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css', rel='stylesheet')
    link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css', rel='stylesheet')
    link(href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap', rel='stylesheet')
    link(rel='stylesheet', href='/css/admin.css')
    
  body.bg-light
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container-fluid
        a.navbar-brand(href='/admin')
          i.fas.fa-home.me-2
          | Panel Admin - Pino Huacho
        
        if user
          .navbar-nav.ms-auto
            .nav-item.dropdown
              a.nav-link.dropdown-toggle(href='#', data-bs-toggle='dropdown')
                i.fas.fa-user.me-2
                = user.username
              ul.dropdown-menu
                li
                  a.dropdown-item(href='/')
                    i.fas.fa-eye.me-2
                    | Ver Sitio Web
                li
                  hr.dropdown-divider
                li
                  a.dropdown-item(href='/admin/logout')
                    i.fas.fa-sign-out-alt.me-2
                    | Cerrar Sesión

    .container-fluid
      .row
        .col-md-3.col-lg-2.px-0
          .sidebar.bg-white.shadow-sm.min-vh-100
            .list-group.list-group-flush
              a.list-group-item.list-group-item-action(href='/admin', class=title.includes('Panel') ? 'active' : '')
                i.fas.fa-tachometer-alt.me-2
                | Dashboard
              
              a.list-group-item.list-group-item-action(href='/admin/reservas', class=title.includes('Reservas') ? 'active' : '')
                i.fas.fa-calendar-alt.me-2
                | Reservas
              
              a.list-group-item.list-group-item-action(href='/admin/calendario', class=title.includes('Calendario') ? 'active' : '')
                i.fas.fa-calendar.me-2
                | Calendario
              
              a.list-group-item.list-group-item-action(href='/admin/precios', class=title.includes('Precios') ? 'active' : '')
                i.fas.fa-dollar-sign.me-2
                | Gestión de Precios
              
              .list-group-item.border-0
                hr
              
              a.list-group-item.list-group-item-action(href='/', target='_blank')
                i.fas.fa-external-link-alt.me-2
                | Ver Sitio Web

        .col-md-9.col-lg-10
          main.py-4
            block content

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
    script(src='/js/admin.js')
    
    block scripts
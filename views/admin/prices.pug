extends layout

block content
  .container-fluid.py-4
    h1.h3.mb-4 Gestión de Precios

    .row
      .col-md-6.mb-4
        .card.shadow
          .card-header.py-3.d-flex.flex-row.align-items-center.justify-content-between
            h6.m-0.font-weight-bold Actualizar Precios por Categoría
          .card-body
            form#updateCategoryForm(action="/admin/precios/update-category" method="POST")
              .mb-3
                label.form-label(for="category") Categoría de Precio
                select.form-select#category(name="category" required)
                  option(value="normal") Normal
                  option(value="weekend") Fin de Semana
                  option(value="high_season") Temporada Alta
                  option(value="holiday") Feriado
                  option(value="special") Especial
              
              .mb-3
                label.form-label(for="categoryPrice") Precio (CLP)
                .input-group
                  span.input-group-text $
                  input.form-control#categoryPrice(type="number" name="price" min="0" step="1000" required)
              
              button.btn.btn-primary.w-100(type="submit") Actualizar Precios por Categoría

      .col-md-6.mb-4
        .card.shadow
          .card-header.py-3.d-flex.flex-row.align-items-center.justify-content-between
            h6.m-0.font-weight-bold Actualizar Precios por Rango de Fechas
          .card-body
            form#updateRangeForm(action="/admin/precios/update-range" method="POST")
              .row
                .col-md-6.mb-3
                  label.form-label(for="startDate") Fecha Inicio
                  input.form-control#startDate(type="date" name="startDate" required)
                
                .col-md-6.mb-3
                  label.form-label(for="endDate") Fecha Fin
                  input.form-control#endDate(type="date" name="endDate" required)
              
              .mb-3
                label.form-label(for="rangePrice") Precio (CLP)
                .input-group
                  span.input-group-text $
                  input.form-control#rangePrice(type="number" name="price" min="0" step="1000" required)
              
              .mb-3
                label.form-label(for="rangeCategory") Categoría (opcional)
                select.form-select#rangeCategory(name="category")
                  option(value="") Sin cambiar categoría
                  option(value="normal") Normal
                  option(value="weekend") Fin de Semana
                  option(value="high_season") Temporada Alta
                  option(value="holiday") Feriado
                  option(value="special") Especial
              
              button.btn.btn-primary.w-100(type="submit") Actualizar Precios por Rango

    .row
      .col-12.mb-4
        .card.shadow
          .card-header.py-3.d-flex.flex-row.align-items-center.justify-content-between
            h6.m-0.font-weight-bold Vista Previa de Precios
          .card-body
            .table-responsive
              table.table.table-bordered
                thead
                  tr
                    th Fecha
                    th Día
                    th Categoría
                    th Precio
                    th Estado
                    th Acciones
                tbody#pricePreviewTable
                  each day in availabilityData
                    tr(class=day.status === 'occupied' ? 'table-danger' : day.status === 'maintenance' ? 'table-warning' : '')
                      td= day.formattedDate
                      td= day.dayOfWeek
                      td= day.priceCategory
                      td= day.formattedPrice
                      td
                        span(class=`badge ${day.status === 'available' ? 'bg-success' : day.status === 'occupied' ? 'bg-danger' : 'bg-warning'}`)= day.status
                      td
                        button.btn.btn-sm.btn-outline-primary.edit-price-btn(data-id=day.id data-date=day.formattedDate data-price=day.price) Editar

    #editPriceModal.modal.fade(tabindex="-1" aria-hidden="true")
      .modal-dialog
        .modal-content
          .modal-header
            h5.modal-title Editar Precio
            button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
          .modal-body
            form#editSinglePriceForm(action="/admin/precios/update-single" method="POST")
              input(type="hidden" name="dayId" id="editDayId")
              .mb-3
                label.form-label(for="editDate") Fecha
                input.form-control#editDate(type="text" readonly)
              
              .mb-3
                label.form-label(for="editPrice") Precio (CLP)
                .input-group
                  span.input-group-text $
                  input.form-control#editPrice(type="number" name="price" min="0" step="1000" required)
              
              .mb-3
                label.form-label(for="editCategory") Categoría
                select.form-select#editCategory(name="category")
                  option(value="normal") Normal
                  option(value="weekend") Fin de Semana
                  option(value="high_season") Temporada Alta
                  option(value="holiday") Feriado
                  option(value="special") Especial
          
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
            button.btn.btn-primary(type="submit" form="editSinglePriceForm") Guardar Cambios

block scripts
  script.
    document.addEventListener('DOMContentLoaded', function() {
      // Handle edit price modal
      const editButtons = document.querySelectorAll('.edit-price-btn');
      const editModal = new bootstrap.Modal(document.getElementById('editPriceModal'));
      
      editButtons.forEach(button => {
        button.addEventListener('click', function() {
          const dayId = this.dataset.id;
          const date = this.dataset.date;
          const price = this.dataset.price;
          
          document.getElementById('editDayId').value = dayId;
          document.getElementById('editDate').value = date;
          document.getElementById('editPrice').value = price;
          
          editModal.show();
        });
      });
      
      // Handle success/error messages from URL parameters
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('success')) {
        const successMessage = getSuccessMessage(urlParams.get('success'));
        showAlert(successMessage, 'success');
      }
      if (urlParams.get('error')) {
        const errorMessage = getErrorMessage(urlParams.get('error'));
        showAlert(errorMessage, 'danger');
      }
    });
    
    function getSuccessMessage(type) {
      const messages = {
        'category-updated': 'Precios actualizados por categoría exitosamente',
        'range-updated': 'Precios actualizados por rango de fechas exitosamente',
        'single-updated': 'Precio individual actualizado exitosamente'
      };
      return messages[type] || 'Operación completada exitosamente';
    }
    
    function getErrorMessage(type) {
      const messages = {
        'category-update-failed': 'Error al actualizar precios por categoría',
        'range-update-failed': 'Error al actualizar precios por rango de fechas',
        'single-update-failed': 'Error al actualizar precio individual'
      };
      return messages[type] || 'Ha ocurrido un error';
    }
    
    function showAlert(message, type) {
      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
      alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      `;
      
      const container = document.querySelector('.container-fluid');
      container.insertBefore(alertDiv, container.firstChild);
      
      // Auto-dismiss after 5 seconds
      setTimeout(() => {
        alertDiv.remove();
      }, 5000);
    }
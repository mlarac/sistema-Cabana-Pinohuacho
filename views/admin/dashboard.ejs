<% extraScripts = `
<script>
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
      window.location.reload();
    }, 300000);
  });
</script>
` %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="display-6 fw-bold">Panel de Administración</h1>
  <div class="text-muted">
    <i class="fas fa-calendar me-2"></i>
    <%= new Date().toLocaleDateString('es-CL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
  </div>
</div>

<!-- Statistics Cards -->
<div class="row g-4 mb-5">
  <div class="col-md-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body p-4">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-primary text-white rounded-3 p-3 me-3">
            <i class="fas fa-calendar-check fa-2x"></i>
          </div>
          <div>
            <h3 class="fw-bold mb-0"><%= stats.totalReservations %></h3>
            <p class="text-muted mb-0">Total Reservas</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body p-4">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-warning text-white rounded-3 p-3 me-3">
            <i class="fas fa-clock fa-2x"></i>
          </div>
          <div>
            <h3 class="fw-bold mb-0"><%= stats.pendingReservations %></h3>
            <p class="text-muted mb-0">Pendientes</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body p-4">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-success text-white rounded-3 p-3 me-3">
            <i class="fas fa-chart-line fa-2x"></i>
          </div>
          <div>
            <h3 class="fw-bold mb-0"><%= stats.thisMonthReservations %></h3>
            <p class="text-muted mb-0">Este Mes</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body p-4">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-info text-white rounded-3 p-3 me-3">
            <i class="fas fa-dollar-sign fa-2x"></i>
          </div>
          <div>
            <h3 class="fw-bold mb-0"><%= stats.thisMonthRevenue %></h3>
            <p class="text-muted mb-0">Ingresos del Mes</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <!-- Recent Reservations -->
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white border-bottom-0 py-3">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-calendar-alt me-2"></i>
            Próximas Reservas
          </h5>
          <a class="btn btn-outline-primary btn-sm" href="/admin/reservas">Ver Todas</a>
        </div>
      </div>

      <div class="card-body p-0">
        <% if (recentReservations && recentReservations.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="bg-light">
              <tr>
                <th class="px-4 py-3">Huésped</th>
                <th class="py-3">Fechas</th>
                <th class="py-3">Huéspedes</th>
                <th class="py-3 text-end">Total</th>
              </tr>
            </thead>
            <tbody>
              <% recentReservations.forEach(function(reservation) { %>
              <tr>
                <td class="px-4 py-3">
                  <div class="fw-bold"><%= reservation.guestName %></div>
                  <div class="small text-muted"><%= reservation.guestEmail %></div>
                </td>
                <td class="py-3">
                  <div class="small">
                    <strong><%= reservation.checkIn %></strong>
                    &nbsp;→&nbsp;
                    <%= reservation.checkOut %>
                  </div>
                </td>
                <td class="py-3">
                  <span class="badge bg-light text-dark"><%= reservation.guests %></span>
                </td>
                <td class="py-3 text-end">
                  <div class="fw-bold"><%= reservation.totalPrice %></div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="text-center py-5">
          <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
          <p class="text-muted">No hay reservas próximas</p>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white border-bottom-0 py-3">
        <h5 class="fw-bold mb-0">
          <i class="fas fa-bolt me-2"></i>
          Acciones Rápidas
        </h5>
      </div>

      <div class="card-body p-4">
        <div class="d-grid gap-3">
          <a class="btn btn-primary btn-lg text-start" href="/admin/reservas">
            <div class="d-flex align-items-center">
              <i class="fas fa-list fa-2x me-3"></i>
              <div>
                <div class="fw-bold">Gestionar Reservas</div>
                <div class="small">Ver, editar y cancelar reservas</div>
              </div>
            </div>
          </a>

          <a class="btn btn-success btn-lg text-start" href="/admin/calendario">
            <div class="d-flex align-items-center">
              <i class="fas fa-calendar fa-2x me-3"></i>
              <div>
                <div class="fw-bold">Calendario</div>
                <div class="small">Gestionar disponibilidad por fechas</div>
              </div>
            </div>
          </a>

          <a class="btn btn-info btn-lg text-start" href="/" target="_blank">
            <div class="d-flex align-items-center">
              <i class="fas fa-eye fa-2x me-3"></i>
              <div>
                <div class="fw-bold">Vista del Sitio</div>
                <div class="small">Ver cómo lo ven los clientes</div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
